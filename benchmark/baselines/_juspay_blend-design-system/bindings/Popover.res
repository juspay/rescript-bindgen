@module("@juspay/blend-design-system") @react.component
external make: (
  ~heading: string=?,
  ~description: string=?,
  ~trigger: React.element,
  ~children: React.element,
  ~showCloseButton: bool=?,
  ~onOpenChange: bool => unit=?,
  @as("open") ~open_: bool=?,
  ~asModal: bool=?,
  ~primaryAction: PopoverTypes.popoverActionType=?,
  ~secondaryAction: PopoverTypes.popoverActionType=?,
  ~sideOffset: float=?,
  ~side: PopoverTypes.side=?,
  ~align: PopoverTypes.align=?,
  ~alignOffset: float=?,
  ~width: float=?,
  ~minWidth: float=?,
  ~maxWidth: float=?,
  ~height: float=?,
  ~minHeight: float=?,
  ~maxHeight: float=?,
  ~zIndex: int=?,
  ~size: PopoverTypes.popoverSize=?,
  ~onClose: unit => unit=?,
  ~shadow: PopoverTypes.shadow=?,
  ~useDrawerOnMobile: bool=?,
  ~avoidCollisions: bool=?,
  ~skeleton: PopoverTypes.popoverSkeletonProps=?,
) => React.element = "Popover"

@module("@juspay/blend-design-system") @react.component
external make: (
  ~height: int=?,
  ~selectedValues: array<string>,
  ~onChange: string => unit,
  ~items: array<MultiSelectSingleSelectTypes.multiSelectMenuGroupType>,
  ~label: string,
  ~sublabel: string=?,
  ~disabled: bool=?,
  ~helpIconHintText: string=?,
  ~name: string=?,
  ~required: bool=?,
  ~variant: MultiSelectSingleSelectTypes.multiSelectVariant=?,
  ~selectionTagType: MultiSelectSingleSelectTypes.multiSelectSelectionTagType=?,
  ~slot: React.element=?,
  ~hintText: string=?,
  ~placeholder: string,
  ~size: MultiSelectSingleSelectTypes.multiSelectMenuSize=?,
  ~enableSearch: bool=?,
  ~searchPlaceholder: string=?,
  ~enableSelectAll: bool=?,
  ~selectAllText: string=?,
  ~maxSelections: float=?,
  ~customTrigger: React.element=?,
  ~useDrawerOnMobile: bool=?,
  ~maxTriggerWidth: float=?,
  ~minTriggerWidth: float=?,
  ~minMenuWidth: float=?,
  ~maxMenuWidth: float=?,
  ~maxMenuHeight: float=?,
  ~alignment: MultiSelectSingleSelectTypes.multiSelectMenuAlignment=?,
  ~side: MultiSelectSingleSelectTypes.multiSelectMenuSide=?,
  ~sideOffset: float=?,
  ~alignOffset: float=?,
  ~inline: bool=?,
  ~onBlur: unit => unit=?,
  ~onFocus: unit => unit=?,
  ~onOpenChange: bool => unit=?,
  ~error: bool=?,
  ~errorMessage: string=?,
  ~showActionButtons: bool=?,
  ~primaryAction: DataTableTypes.columnManagerPrimaryActionConfig=?,
  ~secondaryAction: DataTableTypes.columnManagerSecondaryActionConfig=?,
  ~showItemDividers: bool=?,
  ~showHeaderBorder: bool=?,
  ~fullWidth: bool=?,
  ~enableVirtualization: bool=?,
  ~virtualListItemHeight: float=?,
  ~virtualListOverscan: float=?,
  ~itemsToRender: float=?,
  ~onEndReached: unit => unit=?,
  ~endReachedThreshold: float=?,
  ~hasMore: bool=?,
  ~loadingComponent: React.element=?,
  ~skeleton: MultiSelectSingleSelectTypes.singleSelectSkeletonProps=?,
  ~allowCustomValue: bool=?,
  ~customValueLabel: string=?,
  ~showClearButton: bool=?,
  ~onClearAllClick: unit => unit=?,
  ~multiSelectGroupPosition: ButtonSkeletonTypes.buttonGroupPosition=?,
) => React.element = "MultiSelect"

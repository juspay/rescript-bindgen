type root = {
  ...JsxDOM.domProps,
}
module Nodes = {
  type t
  external fromRoot: root => t = "%identity"
  external asRoot: t => (root) = "%identity"
  external fromText: root => t = "%identity"
  external asText: t => (root) = "%identity"
  external fromBlockquote: root => t = "%identity"
  external asBlockquote: t => (root) = "%identity"
  external fromCode: root => t = "%identity"

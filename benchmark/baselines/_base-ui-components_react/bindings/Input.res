/** zero-cost wrapper: pass the FUNCTION form of `render` — `render={renderFn((…) => …)}` */
external renderFn: ((PositionerSharedTypes.htmlProps, InputTypes.inputState) => React.element) => React.element = "%identity"

@module("@base-ui-components/react") @react.component
external make: (
  ~onValueChange: (string, PositionerSharedTypes.utilsOnCheckedChangeConfig) => unit=?,
  ~defaultValue: CommonTypes.stringOrNumberOrStringArray=?,
  ~form: string=?,
  ~style: InputTypes.inputStyle=?,
  ~title: string=?,
  ~pattern: string=?,
  ~autoFocus: bool=?,
  ~hidden: bool=?,
  ~id: string=?,
  ~tabIndex: int=?,
  ~role: string=?,
  ~rel: string=?,
  @as("aria-checked") ~ariaChecked: [#"true" | #"false" | #mixed]=?,
  @as("aria-controls") ~ariaControls: string=?,
  @as("aria-current") ~ariaCurrent: [#page | #step | #location | #date | #time | #"true" | #"false"]=?,
  @as("aria-describedby") ~ariaDescribedby: string=?,
  @as("aria-disabled") ~ariaDisabled: bool=?,
  @as("aria-expanded") ~ariaExpanded: bool=?,
  @as("aria-haspopup") ~ariaHaspopup: [#menu | #listbox | #tree | #grid | #dialog | #"true" | #"false"]=?,
  @as("aria-hidden") ~ariaHidden: bool=?,
  @as("aria-invalid") ~ariaInvalid: [#grammar | #"false" | #spelling | #"true"]=?,
  @as("aria-label") ~ariaLabel: string=?,
  @as("aria-labelledby") ~ariaLabelledby: string=?,
  @as("aria-live") ~ariaLive: [#off | #polite | #assertive | #rude]=?,
  @as("aria-pressed") ~ariaPressed: [#"true" | #"false" | #mixed]=?,
  @as("aria-required") ~ariaRequired: bool=?,
  @as("aria-selected") ~ariaSelected: bool=?,
  ~children: React.element=?,
  ~onCopy: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onCut: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onPaste: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onFocus: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onBlur: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onChange: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onInput: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onSubmit: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onKeyDown: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onKeyPress: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onKeyUp: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onClick: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onContextMenu: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onDoubleClick: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onDrag: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onDrop: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onMouseDown: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onMouseEnter: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onMouseLeave: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onMouseMove: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onMouseOut: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onMouseOver: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onMouseUp: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onScroll: PositionerSharedTypes.baseUIEvent => unit=?,
  ~onWheel: PositionerSharedTypes.baseUIEvent => unit=?,
  ~disabled: bool=?,
  ~multiple: bool=?,
  ~step: CommonTypes.stringOrNumber=?,
  @as("type") ~type_: ReactTypes.htmlInputTypeAttribute=?,
  ~formAction: CommonTypes.formAction<'a>=?,
  ~formEncType: string=?,
  ~formMethod: string=?,
  ~formNoValidate: bool=?,
  ~formTarget: string=?,
  ~name: string=?,
  ~value: CommonTypes.stringOrNumberOrStringArray=?,
  ~required: bool=?,
  ~readOnly: bool=?,
  ~alt: string=?,
  ~height: CommonTypes.stringOrNumber=?,
  ~src: string=?,
  ~width: CommonTypes.stringOrNumber=?,
  ~accept: string=?,
  ~checked: bool=?,
  ~max: CommonTypes.stringOrNumber=?,
  ~maxLength: int=?,
  ~min: CommonTypes.stringOrNumber=?,
  ~minLength: int=?,
  ~placeholder: string=?,
  ~className: InputTypes.inputClassName=?,
  ~render: React.element=?,  // ⓘ function form: wrap with `renderFn` (zero-cost)
) => React.element = "Input"

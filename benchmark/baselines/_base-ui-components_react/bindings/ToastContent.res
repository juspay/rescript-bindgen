@module("@base-ui-components/react") @react.component
external make: (
  ~style: ContentTypes.toastContentStyle=?,
  ~title: string=?,
  ~autoFocus: bool=?,
  ~hidden: bool=?,
  ~id: string=?,
  ~tabIndex: int=?,
  ~role: string=?,
  ~rel: string=?,
  @as("aria-checked") ~ariaChecked: [#"true" | #"false" | #mixed]=?,
  @as("aria-controls") ~ariaControls: string=?,
  @as("aria-current") ~ariaCurrent: [#page | #step | #location | #date | #time | #"true" | #"false"]=?,
  @as("aria-describedby") ~ariaDescribedby: string=?,
  @as("aria-disabled") ~ariaDisabled: bool=?,
  @as("aria-expanded") ~ariaExpanded: bool=?,
  @as("aria-haspopup") ~ariaHaspopup: [#menu | #listbox | #tree | #grid | #dialog | #"true" | #"false"]=?,
  @as("aria-hidden") ~ariaHidden: bool=?,
  @as("aria-invalid") ~ariaInvalid: [#grammar | #"false" | #spelling | #"true"]=?,
  @as("aria-label") ~ariaLabel: string=?,
  @as("aria-labelledby") ~ariaLabelledby: string=?,
  @as("aria-live") ~ariaLive: [#off | #polite | #assertive | #rude]=?,
  @as("aria-pressed") ~ariaPressed: [#"true" | #"false" | #mixed]=?,
  @as("aria-required") ~ariaRequired: bool=?,
  @as("aria-selected") ~ariaSelected: bool=?,
  ~children: React.element=?,
  ~onCopy: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onCut: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onPaste: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onFocus: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onBlur: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onChange: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onInput: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onSubmit: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onKeyDown: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onKeyPress: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onKeyUp: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onClick: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onContextMenu: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onDoubleClick: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onDrag: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onDrop: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onMouseDown: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onMouseEnter: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onMouseLeave: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onMouseMove: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onMouseOut: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onMouseOver: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onMouseUp: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onScroll: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~onWheel: PositionerTabUtilsTypes.baseUIEvent => unit=?,
  ~className: ContentTypes.toastContentClassName=?,
  ~render: React.element=?,
) => React.element = "ToastContent"

type props = {
  drawerOpen: bool,
  setDrawerOpen: bool => unit,
  renderTrigger: unit => React.element,
  showPresets: bool,
  availablePresets: array<DateRangePickerTypes.dateRangePreset>,
  activePreset: DateRangePickerTypes.dateRangePreset,
  selectedRange?: DateRangePickerTypes.dateRange,
  startTime?: string,
  endTime?: string,
  dateFormat: string,
  handlePresetSelect: DateRangePickerTypes.dateRangePreset => unit,
  handleStartTimeChange: string => unit,
  handleEndTimeChange: string => unit,
  setSelectedRange: DateRangePickerTypes.dateRange => unit,
  setStartDate: string => unit,
  setEndDate: string => unit,
  handleCancel: unit => unit,
  handleApply: unit => unit,
  showCustomDropdownOnly?: bool,
  isDisabled?: bool,
  isApplyDisabled?: bool,
  applyDisabledMessage?: string,
  disableFutureDates?: bool,
  disablePastDates?: bool,
  maxYearOffset?: float,
}

@module("@juspay/blend-design-system")
external make: React.component<props> = "MobileDrawerPresets"

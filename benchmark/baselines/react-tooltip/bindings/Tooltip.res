@module("react-tooltip") @react.component
external make: (
  ~className: string=?,
  ~classNameArrow: string=?,
  ~content: React.element=?,
  ~portalRoot: Dom.element=?,
  ~render: DistTypes.renderConfig => React.element=?,
  ~place: DistTypes.placesType=?,
  ~offset: int=?,
  ~id: string=?,
  ~variant: DistTypes.variantType=?,
  ~anchorSelect: string=?,
  // ⚠️ REVIEW: `wrapper` is `WrapperType` — couldn't be auto-typed exactly; emitted as `string` placeholder. Match the real type by hand.
  ~wrapper: string=?,
  ~children: React.element=?,
  ~openOnClick: bool=?,
  ~positionStrategy: DistTypes.positionStrategy=?,
  // 🛑 BROKEN: `middlewares` is `any[]` — contains `any`; emitted as `string` placeholder and WON'T WORK. Needs a concrete type upstream.
  ~middlewares: string=?,
  ~delayShow: float=?,
  ~delayHide: float=?,
  ~autoClose: float=?,
  ~float: bool=?,
  ~hidden: bool=?,
  ~noArrow: bool=?,
  ~clickable: bool=?,
  ~openEvents: string=?,  // ⚪ loose — was `Partial<Record<"mouseenter" | "focus" | "mouseover" | AnchorClickEvents, boolean>>`
  ~closeEvents: string=?,  // ⚪ loose — was `Partial<Record<AnchorClickEvents | "mouseleave" | "blur" | "mouseout", boolean>>`
  ~globalCloseEvents: DistTypes.globalCloseEvents=?,
  ~imperativeModeOnly: bool=?,
  ~style: JsxDOM.style=?,
  ~position: DistTypes.iPosition=?,
  ~isOpen: bool=?,
  ~defaultIsOpen: bool=?,
  ~disableStyleInjection: CommonTypes.boolOrCore=?,
  ~border: string=?,
  ~opacity: string=?,
  ~arrowColor: string=?,
  ~arrowSize: float=?,
  ~setIsOpen: bool => unit=?,
  ~afterShow: unit => unit=?,
  ~afterHide: unit => unit=?,
  ~disableTooltip: Dom.element => bool=?,
  ~role: string=?,
) => React.element = "Tooltip"

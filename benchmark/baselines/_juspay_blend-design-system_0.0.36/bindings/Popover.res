type props = {
  heading?: string,
  description?: string,
  trigger: React.element,
  children: React.element,
  showCloseButton?: bool,
  onOpenChange?: bool => unit,
  @as("open") open_?: bool,
  asModal?: bool,
  primaryAction?: PopoverTypes.popoverActionType,
  secondaryAction?: PopoverTypes.popoverActionType,
  sideOffset?: float,
  side?: PopoverTypes.popoverSide,
  align?: PopoverTypes.popoverAlign,
  alignOffset?: float,
  width?: float,
  minWidth?: float,
  maxWidth?: float,
  height?: float,
  minHeight?: float,
  maxHeight?: float,
  zIndex?: int,
  size?: PopoverTypes.popoverSize,
  onClose?: unit => unit,
  shadow?: PopoverTypes.popoverShadow,
  useDrawerOnMobile?: bool,
  avoidCollisions?: bool,
  skeleton?: PopoverTypes.popoverSkeletonProps,
}

@module("@juspay/blend-design-system")
external make: React.component<props> = "Popover"

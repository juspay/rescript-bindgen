# dependencies
node_modules/
# ...except golden-fixture vendor stubs (self-contained test inputs, not real deps)
!test/golden/cases/*/node_modules/
!test/golden/cases/*/node_modules/**

# scratch install cache (versions fetched from npm for generation)
.bindgen-cache/

# generated bindings output
generated/

# ReScript compile sandbox build artifacts
test/sandbox/lib/
test/sandbox/.bsb.lock
test/sandbox/src/*.res.mjs
test/sandbox/src/*.res
test/sandbox/node_modules/

# local scratch playground (generated bindings + ReScript build output)
bindgen-playground/

# misc
*.log
.DS_Store

# generated demo outputs (recreated by generate.mjs)
test/binding-compare/Card.d.ts
test/binding-compare/Card.*.res

# scratch manifest from sandbox generation runs
test/sandbox/src/.bindgen-manifest.json

# benchmark runtime scratch (sandboxes, logs, results) — baselines/ ARE committed
benchmark/.work/
